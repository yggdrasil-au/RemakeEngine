{
    "python.analysis.diagnosticsSource": "Pyright",
    "python.analysis.enableAsyncProgram": false,
    "python.analysis.inlayHints.callArgumentNames": "all",
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.exclude": ["**/__pycache__", ".git", "OldModules/**", "OldRemakeRegistry/**", "Source/**", "GameFiles/**", ".VSCodeCounter/**", ".history/**", "**/node_modules", "**/.*"],
    "python.analysis.extraPaths": [
        "./Utils",
        "./EngineApps/api_definitions",
        "./Tools/Blender/blender-4.0.2-windows-x64/4.0/scripts/modules"
    ],
    "python.analysis.stubPath": "./EngineApps/api_definitions",
    "python-envs.defaultEnvManager": "ms-python.python:system",
    "python.languageServer": "Pylance",
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingModuleSource": "none",
        "reportShadowedImports": "none",
        "reportMissingImports": "none",
        "reportInvalidTypeForm": "none"
    },
    "cSpell.words": [
        "Colours",
        "endc",
        "printc"
    ],
    "json.maxItemsComputed": 500000,
    "godotTools.editorPath.godot4": "a:\\RemakeEngine\\Main\\Tools\\Godot\\Godot_v4.5-stable_mono_win64\\Godot_v4.5-stable_mono_win64_console.exe",
    "VSCodeCounter.exclude": [
        "runtime",
        "**/.history/**"
    ],
    "explorerExclude.backup": {},
    "dotnet.backgroundAnalysis.analyzerDiagnosticsScope": "fullSolution",
    "dotnet.backgroundAnalysis.compilerDiagnosticsScope": "fullSolution",
    "files.watcherExclude": {
        "**/.history/**": true
    },
    "files.exclude": {
        "**/.git": false,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.history/**": false
    },
    "files.enableTrash": true,
    "Lua.codeLens.enable": true,
    "Lua.completion.callSnippet": "Both",
    "Lua.doc.regengine": "lua",
    "Lua.hint.arrayIndex": "Enable",
    "Lua.runtime.version": "Moonsharp 2.0.0.0",
    "Lua.workspace.library": [
        "./EngineApps/api_definitions"
    ],
    "window.zoomLevel": 0.2,
    "dotnet.formatting.organizeImportsOnFormat": true,
    "dotnet.typeMembers.propertyGenerationBehavior": "preferThrowingProperties",
    "csharp.debug.console": "integratedTerminal",
    "dotnetAcquisitionExtension.highVerbosity": true,
    "dotnet.enablePublishIssuesToProblems": true,
    "dotnet.enableWorkspaceBasedDevelopment": false,
    "dotnet.preferVisualStudioCodeFileSystemWatcher": false,
    "explorer.autoRevealExclude": {
        "**/.history/**": true
    },
    "explorer.excludeGitIgnore": false,
    "omnisharp.projectFilesExcludePattern": "**/node_modules/**,**/.git/**,**/bower_components/**,**/.history/**",
    "resharper.solution.showLoadingStatus": true,
    "resharper.build.restorePackagesOnBuild": true,
    "resharper.build.outputVerbosityLevel": "Detailed",
    "dotnetAcquisitionExtension.enableTelemetry": false,
    "dotnet.diagnostics.reportInformationAsHint": false,
    "dotnet.inlayHints.enableInlayHintsForIndexerParameters": true,
    "dotnet.inlayHints.enableInlayHintsForLiteralParameters": true,
    "dotnet.inlayHints.enableInlayHintsForOtherParameters": true,
    "dotnet.inlayHints.enableInlayHintsForParameters": true,
    "dotnet.inlayHints.suppressInlayHintsForParametersThatDifferOnlyBySuffix": false,
    "dotnet.navigation.navigateToDecompiledSources": false,
    "dotnet.projects.enableFileBasedPrograms": false,
    "dotnet.server.sourceGeneratorExecution": "Automatic",
    "dotnet.automaticallyCreateSolutionInWorkspace": false,
    "dotnet.projects.excludeGlob": "**/.history/**",
    "csharp.metadataExcludePaths": [
        "**/.history/**"
    ],
    "search.exclude": {
        "**/.history": true
    },
    "dotnet.defaultSolution": "RemakeEngine.slnx",
    "Lua.diagnostics.libraryFiles": "Enable",
    "Lua.hint.enable": true,
    "Lua.completion.maxSuggestCount": 500,
    "Lua.completion.showWord": "Enable",
    "Lua.diagnostics.ignoredFiles": "Enable",
    "Lua.hint.setType": true,
    "Lua.runtime.path": [],
    "Lua.type.inferParamType": true,
    "Lua.type.checkTableShape": true,
    "Lua.workspace.ignoreDir": [
        ".betterGit",
        ".github",
        ".history",
        ".idea",
        ".vscode",
        ".VSCodeCounter",
        "EngineApps/Registries",
        "Registries",
        "EngineApps/Tools",
        "Tools",
        "__pycache__",
        "GameFiles",
        "Source",
        "EngineBuild",
        "EngineNet",
        "logs",
        "RemakeEngineDocs",
        "schemas",
        "tmp"
    ],
    "Lua.workspace.ignoreSubmodules": false,
    "Lua.workspace.useGitIgnore": false,
}

