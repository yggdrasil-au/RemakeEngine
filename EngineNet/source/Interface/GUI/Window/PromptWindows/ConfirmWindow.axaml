<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="EngineNet.Interface.GUI.Pages.PromptWindows.ConfirmWindow"
    Width="360" Height="150"
    WindowStartupLocation="CenterOwner"
    CanResize="False">
    <Grid Margin="8" RowDefinitions="*,Auto,Auto">
        <TextBlock
            x:Name="Question"
            Grid.Row="0"
            TextWrapping="Wrap"/>
        <CheckBox
            x:Name="DontAskAgainCheck"
            Grid.Row="1"
            Content="Don't ask again"
            IsVisible="False"
            Margin="0,8,0,0"/>
        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,8,0,0">
            <Button
                Content="Yes" Width="80"
                Margin="0,0,8,0" Click="OnYes"/>
            <Button
                Content="No" Width="80"
                Click="OnNo"/>
        </StackPanel>
    </Grid>
</Window>
