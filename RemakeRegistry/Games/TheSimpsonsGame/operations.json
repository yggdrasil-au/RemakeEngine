{
	"The Simpsons Game": [
		{
			"init": true,
			"Instructions": "run main init",
			"python_executable": "python",
			"script": "RemakeRegistry/Games/TheSimpsonsGame/Scripts/init.py",
			"args": []
		},
		{
			"Name": "validate game files",
			"Instructions": "run validate against the `RemakeRegistry/Games/TheSimpsonsGame/Primary_Index.db`, specifically the root files in the source folder",
			"python_executable": "python",
			"script": "",
			"args": []
		},
		{
			"Name": "Rename base folders",
			"Instructions": "run rename script",
			"python_executable": "python",
			"script": "Tools/Process/Rename/RenameFolders.py",
			"args": ["{{RemakeEngine.Directories.SourcePath}}", "--map-db-file", "RemakeRegistry/Games/TheSimpsonsGame/RenameMap.db"]
		},
		{
			"Name": "Extract Archives (.STR)",
			"Instructions": "run quickbms script using RemakeRegistry/Games/TheSimpsonsGame/Scripts/simpsons_str.bms",
			"python_executable": "python",
			"script": "Tools/QuickBMS/extract_str.py",
			"args": ["--quickbms", "Tools/QuickBMS/exe/quickbms.exe", "--script", "RemakeRegistry/Games/TheSimpsonsGame/Scripts/simpsons_str.bms", "--input", "{{RemakeEngine.Directories.SourcePath}}", "--output", "GameFiles/STROUT", "--extension", ".str"]
		},
		{
			"Name": "Extract Textures (.txd -> .dds)",
			"python_executable": "python",
			"script": "RemakeRegistry/Games/TheSimpsonsGame/Scripts/Texture/Export_txd.py",
			"args": ["GameFiles/STROUT"]
		},
		{
			"Name": "validate extracted game files",
			"Instructions": "run validate against the `RemakeRegistry/Games/TheSimpsonsGame/Primary_Index.db`",
			"python_executable": "python",
			"script": "",
			"args": []
		},
		{
			"Name": "flatten folder structure",
			"Instructions": "run flatten script",
			"python_executable": "python",
			"script": "Tools/Process/Flat/flat.py",
			"args": ["GameFiles/STROUT", "GameFiles/ExtractedOut", "--rules", "RemakeRegistry/Games/TheSimpsonsGame/PathRules.json", "--separator", "++", "--verbose"]
		},
		{
			"Name": "Convert Models (.preinstanced -> .blend)",
			"python_executable": "python",
			"script": "",
			"prompts": [
			{
				"type": "confirm",
				"Name": "verbose",
				"message": "Model Conversion: Enable verbose output?",
				"default": false,
				"cli_arg": "--verbose"
			},
			{
				"type": "confirm",
				"Name": "debug_sleep",
				"message": "Model Conversion: Enable debug sleep?",
				"default": false,
				"cli_arg": "--debug-sleep"
			},
			{
				"type": "confirm",
				"Name": "enable_export",
				"message": "Model Conversion: Export additional formats (FBX/GLTF)?",
				"default": false
			},
			{
				"type": "checkbox",
				"Name": "export_formats",
				"message": "Select export formats:",
				"choices": ["fbx", "glb"],
				"cli_prefix": "--export",
				"condition": "enable_export",
				"validation": {"required": true, "message": "You must select at least one format."}
			}
			],
			"args": []
		},
		{
			"Name": "Convert Videos (.vp6 -> .ogv)",
			"python_executable": "python",
			"script": "",
			"args": []
		},
